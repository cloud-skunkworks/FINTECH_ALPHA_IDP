{
  "name": "idp-platform-cdk",
  "version": "1.0.0",
  "description": "FinTech IDP Platform — AWS CDK Infrastructure",
  "main": "lib/index.js",
  "scripts": {
    "build": "tsc",
    "watch": "tsc -w",
    "test": "jest",
    "synth": "cdk synth",
    "diff": "cdk diff",
    "deploy": "cdk deploy",
    "destroy": "cdk destroy",
    "lint": "eslint 'lib/**/*.ts' 'bin/**/*.ts' 'test/**/*.ts'"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "20.11.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "aws-cdk": "2.160.0",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.2",
    "typescript": "~5.4.0"
  },
  "dependencies": {
    "aws-cdk-lib": "2.160.0",
    "constructs": "^10.3.0"
  },
  "jest": {
    "testEnvironment": "node",
    "roots": [
      "<rootDir>/test"
    ],
    "testMatch": [
      "**/*.test.ts"
    ],
    "transform": {
      "^.+\\.tsx?$": "ts-jest"
    }
  }
}
